{
  "manifest_version": 3,
  "name": "Fantrax to Fangraphs Linker",
  "version": "1.0",
  "description": "Adds a Fangraphs link next to player names on Fantrax rosters.",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.fantrax.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "player_lookup.json"
      ],
      "matches": [
        "*://*.fantrax.com/*"
      ]
    }
  ],
  "permissions": []
}